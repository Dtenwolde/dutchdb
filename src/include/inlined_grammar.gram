IfExists <- 'INDIEN' 'BESTAAT'
QualifiedSchemaName <- CatalogQualification? SchemaName

DropSecretStorage <- 'VAN' Identifier
UpdateStatement <- WithClause? 'BIJWERKEN' UpdateTarget UpdateSetClause FromClause? WhereClause? ReturningClause?

