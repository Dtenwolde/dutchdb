GlobalScope <- 'GLOBAAL'

SetAssignment <- VariableAssign VariableList

VariableAssign <- '=' / 'NAAR'
VariableList <- List(Expression)

ResetStatement <- 'HERSTELLEN' (SetVariable / SetSetting)

ExportStatement <- 'EXPORTEREN' 'DATABASE' ExportSource? StringLiteral GenericCopyOptionList?

ExportSource <- CatalogName 'NAAR'

ImportStatement <- 'IMPORTEREN' 'DATABASE' StringLiteral

CheckpointStatement <- 'FORCEREN'? 'CONTROLEPUNT' CatalogName?

CopyStatement <- 'KOPIEREN' (CopyTable / CopySelect / CopyFromDatabase)

CopyTable <- BaseTableName InsertColumnList? FromOrTo CopyFileName CopyOptions?
FromOrTo <- 'VAN' / 'NAAR'

CopySelect <- Parens(SelectStatementInternal) 'NAAR' CopyFileName CopyOptions?

CopyFileName <- Parameter / ParensExpression / StringLiteral / Identifier / (Identifier '.' ColId)
CopyOptions <- 'MET'? GenericCopyOptionList / SpecializedOptionList
SpecializedOptionList <- SpecializedOption*
SpecializedOption <- SingleOption / NullAsOption / DelimiterAsOption / EscapeAsOption /
	EncodingOption / QuoteAsOption / ForceQuoteOption / PartitionByOption / ForceNullOption

SingleOption <- BinaryOption / FreezeOption / OidsOption / CsvOption / HeaderOption
BinaryOption <- 'BINAIR'
FreezeOption <- 'BEVRIEZEN'
OidsOption <- 'OIDS'
CsvOption <- 'CSV'
HeaderOption <- 'KOPTEKST'
NullAsOption <- 'LEEG' 'ALS'? StringLiteral
DelimiterAsOption <- 'SCHEIDINGSTEKEN' 'ALS'? StringLiteral
QuoteAsOption <- 'AANHALINGSTEKEN' 'ALS'? StringLiteral
EscapeAsOption <- 'ONTSNAPPEN' 'ALS'? StringLiteral
EncodingOption <- 'CODERING' StringLiteral
ForceQuoteOption <- 'FORCEREN'? 'AANHALINGSTEKEN' (StarSymbol / ColumnList)
PartitionByOption <- 'PARTITIE' 'PER' (StarSymbol / ColumnList)
ForceNullOption <- 'FORCEREN' 'NIET'? 'LEEG' ColumnList
StarSymbol <- '*'

GenericCopyOptionList <- Parens(List(GenericCopyOption))
GenericCopyOption <- CopyOptionName Expression?

CopyFromDatabase <- 'VAN' 'DATABASE' ColId 'NAAR' ColId CopyDatabaseFlag?

CopyDatabaseFlag <- Parens(SchemaOrData)
SchemaOrData <- CopySchema / CopyData
CopySchema <- 'SCHEMA'
CopyData <- 'GEGEVENS'

AlterStatement <- 'WIJZIGEN' AlterOptions

AlterOptions <- AlterTableStmt / AlterViewStmt / AlterSequenceStmt / AlterDatabaseStmt / AlterSchemaStmt

AlterTableStmt <- 'TABEL' IfExists? BaseTableName AlterTableOptions
AlterSchemaStmt <- 'SCHEMA' IfExists? QualifiedName RenameAlter

AlterTableOptions <- AddColumn / DropColumn / AlterColumn / AddConstraint / ChangeNullability /
        RenameColumn / RenameAlter / SetPartitionedBy / ResetPartitionedBy / SetSortedBy / ResetSortedBy / SetOptions / ResetOptions

AddConstraint <- 'BIJVOEGEN' TopLevelConstraint
AddColumn <- 'BIJVOEGEN' 'KOLOM'? IfNotExists? AddColumnEntry
AddColumnEntry <- DottedIdentifier Type? GeneratedColumn? ColumnConstraint*
DropColumn <- 'GOOI_WEG' 'KOLOM'? IfExists? NestedColumnName DropBehavior?
AlterColumn <- 'WIJZIGEN' 'KOLOM'? NestedColumnName AlterColumnEntry
RenameColumn <- 'HERNOEMEN' 'KOLOM'? NestedColumnName 'NAAR' Identifier
NestedColumnName <- (Identifier '.')* ColumnName
RenameAlter <- 'HERNOEMEN' 'NAAR' Identifier
SetPartitionedBy <- 'INSTELLEN' 'GEPARTITIONEERD' 'PER' Parens(List(Expression))
ResetPartitionedBy <- 'HERSTELLEN' 'GEPARTITIONEERD' 'PER'
SetSortedBy <- 'INSTELLEN' 'GESORTEERD' 'PER' Parens(OrderByExpressions)
ResetSortedBy <- 'HERSTELLEN' 'GESORTEERD' 'PER'
SetOptions <- 'INSTELLEN' RelOptionList
ResetOptions <- 'HERSTELLEN' RelOptionList

AlterColumnEntry <- AddOrDropDefault / ChangeNullability / AlterType

AddOrDropDefault <- AddDefault / DropDefault
AddDefault <- 'INSTELLEN' 'STANDAARD' Expression
DropDefault <- 'GOOI_WEG' 'STANDAARD'

ChangeNullability <- DropOrSet 'NIET' 'LEEG'
DropOrSet <- 'GOOI_WEG' / 'INSTELLEN'

AlterType <- SetData? 'TYPE' Type? UsingExpression?
SetData <- 'INSTELLEN' 'GEGEVENS'?
UsingExpression <- 'GEBRUIKEN' Expression

AlterViewStmt <- 'WEERGAVE' IfExists? BaseTableName RenameAlter

AlterSequenceStmt <- 'AANEENVOLGING' IfExists? QualifiedSequenceName AlterSequenceOptions

QualifiedSequenceName <- CatalogQualification? SchemaQualification? SequenceName

AlterSequenceOptions <- RenameAlter / SetSequenceOption
SetSequenceOption <- List(SequenceOption)

AlterDatabaseStmt <- 'DATABASE' IfExists? Identifier 'INSTELLEN' 'ALIAS' 'NAAR' Identifier

CreateSequenceStmt <- 'AANEENVOLGING' IfNotExists? QualifiedName SequenceOption*

SequenceOption <-
	SeqSetCycle /
	SeqSetIncrement /
	SeqSetMinMax /
	SeqNoMinMax /
	SeqStartWith /
	SeqOwnedBy

SeqSetCycle <- 'NEEN'? 'CYCLUS'
SeqSetIncrement <- 'VERHOGING' 'PER'? Expression
SeqSetMinMax <- SeqMinOrMax Expression
SeqNoMinMax <- 'NEEN' SeqMinOrMax
SeqStartWith <- 'STARTEN' 'MET'? Expression
SeqOwnedBy <- 'EIGENDOM' 'PER' QualifiedName

SeqMinOrMax <- MinValue / MaxValue
MinValue <- 'MINIMUMWAARDE'
MaxValue <- 'MAXIMUMWAARDE'
ExplainStatement <- 'UITLEGGEN' 'ANALYSEER'? GenericCopyOptionList? ExplainableStatements

ExplainableStatements <-
    AlterStatement /
    AnalyzeStatement /
    CallStatement /
    CheckpointStatement /
    CopyStatement /
    CreateStatement /
    DeallocateStatement /
    DeleteStatement /
    DropStatement /
    ExecuteStatement /
    InsertStatement /
    LoadStatement /
    MergeIntoStatement /
    PragmaStatement /
    PrepareStatement /
    SelectStatementInternal /
    TransactionStatement /
    UpdateStatement /
    VacuumStatement /
    SetStatement /
    ResetStatement
AnalyzeStatement <- 'ANALYSEER' 'UITGEBREID'? AnalyzeTarget?
AnalyzeTarget <- BaseTableName NameList?
CreateMacroStmt <- MacroOrFunction IfNotExists? QualifiedName List(MacroDefinition)

MacroOrFunction <- 'MACRO' / 'FUNCTIE'

MacroDefinition <- Parens(MacroParameters?) 'ALS' (TableMacroDefinition / ScalarMacroDefinition)

MacroParameters <- List(MacroParameter)
MacroParameter <- NamedParameter / SimpleParameter
SimpleParameter <- TypeFuncName Type?

ScalarMacroDefinition <- Expression
TableMacroDefinition <- 'TABEL' SelectStatementInternal

CommentStatement <- 'OPMERKING' 'OP' CommentOnType DottedIdentifier 'IS' CommentValue

CommentOnType <-    CommentTable / CommentSequence / CommentFunction / CommentMacroTable / CommentMacro /
                    CommentView / CommentDatabase / CommentIndex / CommentSchema / CommentType / CommentColumn

CommentTable <- 'TABEL'
CommentSequence <- 'AANEENVOLGING'
CommentFunction <- 'FUNCTIE'
CommentMacroTable <- 'MACRO' 'TABEL'
CommentMacro <- 'MACRO'
CommentView <- 'WEERGAVE'
CommentDatabase <- 'DATABASE'
CommentIndex <- 'INDEX'
CommentSchema <- 'SCHEMA'
CommentType <- 'TYPE'
CommentColumn <- 'KOLOM'

CommentValue <- 'LEEG' / StringLiteral
AttachStatement <- 'KOPPELEN' OrReplace? IfNotExists? Database? DatabasePath AttachAlias? AttachOptions?

Database <- 'DATABASE'
DatabasePath <- StringLiteral
AttachAlias <- 'ALS' ColId
AttachOptions <- GenericCopyOptionList

DetachStatement <- 'ONTKOPPELEN' Database? IfExists? CatalogName

UseStatement <- 'GEBRUIK' UseTarget

UseTarget <- (CatalogName '.' ReservedSchemaName) / SchemaName / CatalogName

CallStatement <- 'AANROEPEN' QualifiedTableFunction TableFunctionArguments

