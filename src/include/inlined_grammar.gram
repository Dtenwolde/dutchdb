IndexType <- 'GEBRUIKEN' Identifier
RelOption <- RelOptionName RelOptionArgumentOpt?
RelOptionName <- DottedIdentifier / StringLiteral
RelOptionArgumentOpt <- '=' DefArg
DefArg <- NullLiteral / ReservedKeyword / StringLiteral / NumberLiteral / NoneLiteral / Expression
ReservedKeywordValue <- ReservedKeyword
NoneLiteral <- 'GEEN'

LoadStatement <- 'LADEN' ColIdOrString
InstallStatement <- 'FORCEREN'? 'INSTALLEREN' IdentifierOrStringLiteral FromSource? VersionNumber?
FromSource <- 'VAN' (Identifier / StringLiteral)
VersionNumber <- Identifier
DropStatement <- 'GOOI_WEG' DropEntries DropBehavior?

DropEntries <-
	DropTable /
	DropTableFunction /
	DropFunction /
	DropSchema /
	DropIndex /
	DropSequence /
	DropCollation /
	DropType /
	DropSecret

