ConstraintNameClause <- 'BEPERKING' Identifier
TopPrimaryKeyConstraint <- 'PRIMAIR' 'SLEUTEL' ColumnIdList
TopUniqueConstraint <- 'UNIEK' ColumnIdList
TopForeignKeyConstraint <- 'VREEMD' 'SLEUTEL' ColumnIdList ForeignKeyConstraint
ColumnIdList <- Parens(List(ColId))

PlainIdentifier <- !ReservedKeyword <[a-z_]i[a-z0-9_]i*>
QuotedIdentifier <- '"' [^"]* '"'
DottedIdentifier <- Identifier ('.' Identifier)*
Identifier <- QuotedIdentifier / PlainIdentifier

